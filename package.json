{
  "name": "cryptoreportkit-desktop",
  "version": "1.0.0",
  "description": "CryptoReportKit Desktop - Privacy-first crypto analytics",
  "main": "src/main/main.js",
  "author": "CryptoReportKit",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"wait-on http://localhost:1420 && npm run dev:electron\"",
    "dev:renderer": "vite --port 1420",
    "dev:electron": "node -e \"delete process.env.ELECTRON_RUN_AS_NODE; require('child_process').spawn(require('electron'), ['.'], {stdio:'inherit'}).on('close',process.exit)\"",
    "build": "vite build && npm run build:electron",
    "build:electron": "electron-builder --win --x64",
    "build:mac": "vite build && electron-builder --mac",
    "build:linux": "vite build && electron-builder --linux",
    "build:all": "vite build && electron-builder --win --mac --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.cryptoreportkit.desktop",
    "productName": "CryptoReportKit",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "!node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}_${version}_${arch}-setup.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "CryptoReportKit"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.finance"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build",
      "category": "Finance"
    },
    "publish": {
      "provider": "github",
      "owner": "sasmalgiri",
      "repo": "cryptoreportkit-desktop"
    }
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.0",
    "keytar": "^7.9.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "lucide-react": "^0.561.0",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "recharts": "^2.15.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0",
    "zustand": "^5.0.0"
  }
}
